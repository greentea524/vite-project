{
  // Type-checks only the Treasure Hunt game (the rest of the repo is JSX).
  // Vite transpiles TS without this file; run `npx tsc --noEmit` to check.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "forceConsistentCasingInFileNames": true
  },
  "include": ["treasure/**/*.ts"]
}
